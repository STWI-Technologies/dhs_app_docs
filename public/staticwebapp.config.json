{
  "globalHeaders": {
    "Access-Control-Allow-Origin": "*",
    "Access-Control-Allow-Methods": "POST, GET, OPTIONS"
  },
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/images/*", "/content/*", "/brand/*", "/en/*", "/es/*", "/sitemap.xml", "/robots.txt"]
  },
  "routes": [
    {
      "route": "/sitemap.xml",
      "headers": {
        "Content-Type": "application/xml"
      }
    },
    {
      "route": "/robots.txt",
      "headers": {
        "Content-Type": "text/plain"
      }
    }
  ],
  "mimeTypes": {
    ".xml": "application/xml"
  }
}
